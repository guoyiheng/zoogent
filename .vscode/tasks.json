{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build and Run zoogent (macOS)",
			"type": "shell",
			"command": "/Applications/Xcode.app/Contents/Developer/usr/bin/xcodebuild",
			"args": [
				"-project",
				"zoogent.xcodeproj",
				"-scheme",
				"LilAgents",
				"-configuration",
				"Debug",
				"-derivedDataPath",
				"./build",
				"build",
				"&&",
				"open",
				"./build/Build/Products/Debug/zoogent.app"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		}
	]
}